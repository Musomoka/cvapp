# Backend API URL
# In development: http://localhost:3001
# In production: your Render backend service URL (e.g. https://cvapp-backend.onrender.com)
VITE_API_URL=http://localhost:3001

# Google OAuth Client ID (from Google Cloud Console → APIs & Services → Credentials)
# Must be the same Client ID configured in your backend GOOGLE_CLIENT_ID env var
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
