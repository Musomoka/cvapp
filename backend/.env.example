# DeepSeek API Configuration (Recommended - Very Cheap!)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
API_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# Alternative: OpenAI Configuration (if using OpenAI instead)
# OPENAI_API_KEY=your_openai_api_key_here
# API_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-3.5-turbo

# Server Configuration
PORT=3001
NODE_ENV=development

# Security — required in production (auto-generated by Render, or set a long random string)
JWT_SECRET=your-long-random-secret-here

# Data directory for JSON persistence
# Defaults to ./data relative to the backend folder
# On Render, set to the persistent disk mount path (e.g. /var/data)
DATA_DIR=./data

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
